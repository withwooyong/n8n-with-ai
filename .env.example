# =============================================================================
# n8n-mcp 연결용 (n8n Editor → Settings → API 에서 발급)
# =============================================================================
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=여기에_발급받은_API_키를_붙여넣기


# =============================================================================
# "고객 문의 자동 응대 시스템" 워크플로우용 Credential 값
# 아래 값들을 채워 .env 로 복사한 뒤, n8n-mcp 의 manage_credentials 로 등록하거나
# n8n UI 의 Credentials 메뉴에서 직접 입력한다.
# =============================================================================

# -----------------------------------------------------------------------------
# 1) Google 공통 — 스프레드시트 ID
#    https://docs.google.com/spreadsheets/d/<<여기>>/edit 의 <<여기>> 부분
#    `고객문의_폼` / `고객문의_로그` 시트가 같은 문서 안에 있어야 한다.
# -----------------------------------------------------------------------------
GOOGLE_SHEETS_DOCUMENT_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789AbCd
GOOGLE_SHEET_INPUT_NAME=고객문의_폼
GOOGLE_SHEET_LOG_NAME=고객문의_로그

# -----------------------------------------------------------------------------
# 2) Google Cloud OAuth 2.0 클라이언트 (Google Sheets + Gmail 공용)
#    Google Cloud Console → APIs & Services → Credentials → Create credentials
#    → OAuth client ID → Web application
#    승인 리디렉션 URI:
#      http://localhost:5678/rest/oauth2-credential/callback
#    활성화할 API: Google Sheets API, Gmail API
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=123456789012-abcdefghijklmnopqrstuvwxyz012345.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 3) OpenAI API Key (현재 운영 사용)
#    https://platform.openai.com/api-keys
#    모델: gpt-4o-mini (Responses API 지원)
#    n8n credential type: openAiApi, name: "OpenAI account"
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# 3-a) (선택) Google Gemini API Key — 이전 버전 호환 / fallback
#      현재 운영에서 OpenAI 로 교체됨 (무료 등급 RPM 한도 및 503 빈발 이슈).
#      https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# 4) Slack Bot Token
#    https://api.slack.com/apps → Create New App → From scratch
#    Bot Token Scopes: chat:write, chat:write.public, channels:read
#    (scope 변경 시 반드시 "Reinstall to Workspace" 로 토큰 재발급 — 기존 토큰은 옛 scope 만 포함)
#    Install to Workspace → Bot User OAuth Token 복사
#    봇을 아래 두 채널에 반드시 초대 (/invite @봇이름)
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-REPLACE-WITH-YOUR-BOT-USER-OAUTH-TOKEN
SLACK_CHANNEL_CUSTOMER_SUPPORT=#customer-support
SLACK_CHANNEL_ERROR_ALERT=#error-alert


# =============================================================================
# (참고) OpenAI API 동작 확인용 curl — 키 유효성 빠르게 테스트
# =============================================================================
# curl "https://api.openai.com/v1/responses" \
#   -H "Content-Type: application/json" \
#   -H "Authorization: Bearer ${OPENAI_API_KEY}" \
#   -d '{
#     "model": "gpt-4o-mini",
#     "input": "ping",
#     "max_output_tokens": 16
#   }' | jq '.output[0].content[0].text'

# (참고) Gemini API curl (legacy)
# curl "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent" \
#   -H 'Content-Type: application/json' \
#   -H "X-goog-api-key: ${GEMINI_API_KEY}" \
#   -X POST \
#   -d '{"contents":[{"parts":[{"text":"Explain how AI works in a few words"}]}]}'
